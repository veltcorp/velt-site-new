<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= post ? 'Editar' : 'Nova' %> Postagem - Blog Velt Admin
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/easymde/dist/easymde.min.css">
    <script src="https://unpkg.com/easymde/dist/easymde.min.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { primary: '#FF6B00', secondary: '#1E293B' },
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .EasyMDEContainer .CodeMirror {
            border-radius: 0 0 0.5rem 0.5rem;
            border-color: #e2e8f0;
            min-height: 400px;
            font-size: 15px;
        }

        .EasyMDEContainer .editor-toolbar {
            border-color: #e2e8f0;
            border-radius: 0.5rem 0.5rem 0 0;
            background: #f8fafc;
        }

        .EasyMDEContainer .editor-toolbar button.active,
        .EasyMDEContainer .editor-toolbar button:hover {
            background: #FF6B00;
            color: white;
            border-color: #FF6B00;
        }

        .seo-indicator {
            transition: all 0.3s;
        }

        .seo-good {
            color: #16a34a;
        }

        .seo-warn {
            color: #eab308;
        }

        .seo-bad {
            color: #cbd5e1;
        }
    </style>
</head>

<body class="bg-slate-50 text-slate-800 min-h-screen">

    <!-- Top Navigation -->
    <nav class="bg-secondary text-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center gap-8">
                    <span class="font-bold text-xl text-primary">Velt Admin</span>
                    <a href="/admin" class="text-white/60 hover:text-white text-sm font-medium flex items-center gap-1">
                        <span class="material-icons text-sm">arrow_back</span> Voltar aos Posts
                    </a>
                </div>
                <div class="flex items-center gap-4">
                    <a href="http://localhost:8082" target="_blank"
                        class="text-white/60 hover:text-white text-sm flex items-center gap-1">
                        Ver Site <span class="material-icons text-sm">open_in_new</span>
                    </a>
                    <a href="/admin/logout" class="text-white/60 hover:text-white text-sm flex items-center gap-1">
                        <span class="material-icons text-sm">logout</span> Sair
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">

        <!-- Page Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-slate-900">
                <%= post ? 'Editar Postagem' : 'Nova Postagem' %>
            </h1>
            <p class="mt-1 text-sm text-slate-500">Preencha os campos abaixo. O assistente de SEO à direita ajudará você
                a otimizar o conteúdo.</p>
        </div>

        <form action="/admin/save" method="POST" id="postForm">
            <input type="hidden" name="filename" value="<%= post ? post.filename : '' %>">

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

                <!-- ============ LEFT COLUMN: Editor ============ -->
                <div class="lg:col-span-2 space-y-6">

                    <!-- Metadata Card -->
                    <div class="bg-white shadow-sm rounded-xl border border-slate-200 p-6">
                        <h2 class="text-lg font-semibold text-slate-900 mb-4 flex items-center gap-2">
                            <span class="material-icons text-primary">tune</span> Metadados do Artigo
                        </h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <!-- Title -->
                            <div class="md:col-span-2">
                                <label for="title" class="block text-sm font-medium text-slate-700 mb-1">Título do
                                    Artigo</label>
                                <input type="text" name="title" id="title" value="<%= post ? post.title : '' %>"
                                    required placeholder="Ex: O Futuro das Viagens Corporativas em 2026"
                                    class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition">
                                <p class="mt-1 text-xs seo-indicator seo-bad" id="title-counter">0 / 60 caracteres</p>
                            </div>

                            <!-- Author -->
                            <div>
                                <label for="author" class="block text-sm font-medium text-slate-700 mb-1">Autor</label>
                                <input type="text" name="author" id="author"
                                    value="<%= post ? post.author : 'Equipe Velt' %>" required
                                    class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition">
                            </div>

                            <!-- Date -->
                            <div>
                                <label for="date" class="block text-sm font-medium text-slate-700 mb-1">Data de
                                    Publicação</label>
                                <input type="date" name="date" id="date"
                                    value="<%= post ? post.date : new Date().toISOString().split('T')[0] %>" required
                                    class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition">
                            </div>

                            <!-- Description -->
                            <div class="md:col-span-2">
                                <label for="description" class="block text-sm font-medium text-slate-700 mb-1">Meta
                                    Descrição (SEO)</label>
                                <textarea name="description" id="description" rows="3" required
                                    placeholder="Uma descrição concisa do artigo para o Google (150-160 caracteres ideal)"
                                    class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition resize-none"><%= post ? post.description : '' %></textarea>
                                <p class="mt-1 text-xs seo-indicator seo-bad" id="desc-counter">0 / 160 caracteres</p>
                            </div>

                            <!-- Image -->
                            <div class="md:col-span-2">
                                <label for="image" class="block text-sm font-medium text-slate-700 mb-1">Imagem de
                                    Capa</label>
                                <div class="flex rounded-lg overflow-hidden border border-slate-300">
                                    <input type="text" name="image" id="image" value="<%= post ? post.image : '' %>"
                                        required placeholder="https://images.unsplash.com/..."
                                        class="flex-1 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40 border-0">
                                    <button type="button"
                                        class="px-4 py-2 bg-slate-100 text-slate-600 text-sm font-medium hover:bg-slate-200 transition border-l border-slate-300 flex items-center gap-1"
                                        id="upload-trigger">
                                        <span class="material-icons text-sm">cloud_upload</span> Upload
                                    </button>
                                </div>
                                <input type="file" id="file-upload" class="hidden" accept="image/*">
                                <!-- Image Preview -->
                                <div id="image-preview" class="mt-3 hidden">
                                    <img id="preview-img" src="" alt="Preview"
                                        class="w-full h-40 object-cover rounded-lg border border-slate-200">
                                </div>
                            </div>

                            <!-- Tags -->
                            <div class="md:col-span-2">
                                <label for="tags" class="block text-sm font-medium text-slate-700 mb-1">Tags</label>
                                <input type="text" name="tags" id="tags" value="<%= post ? post.tags : '' %>"
                                    placeholder="Tecnologia, Inovação, Viagens"
                                    class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition">
                                <p class="mt-1 text-xs text-slate-400">Separadas por vírgula</p>
                            </div>
                        </div>
                    </div>

                    <!-- Markdown Editor Card -->
                    <div class="bg-white shadow-sm rounded-xl border border-slate-200 overflow-hidden">
                        <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between">
                            <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
                                <span class="material-icons text-primary">edit_note</span> Conteúdo do Artigo
                            </h2>
                            <span class="text-xs text-slate-400" id="word-count">0 palavras</span>
                        </div>
                        <div class="px-2">
                            <textarea name="content" id="markdown-editor"><%= post ? post.body : '' %></textarea>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div
                        class="flex justify-between items-center bg-white shadow-sm rounded-xl border border-slate-200 p-4">
                        <a href="/admin"
                            class="px-4 py-2 text-sm font-medium text-slate-600 bg-slate-100 rounded-lg hover:bg-slate-200 transition flex items-center gap-1">
                            <span class="material-icons text-sm">close</span> Cancelar
                        </a>
                        <div class="flex gap-3">
                            <button type="submit"
                                class="px-6 py-2.5 text-sm font-bold text-white bg-primary rounded-lg hover:bg-orange-700 transition shadow-sm flex items-center gap-2">
                                <span class="material-icons text-sm">save</span> Salvar e Publicar
                            </button>
                        </div>
                    </div>
                </div>

                <!-- ============ RIGHT COLUMN: SEO Sidebar ============ -->
                <div class="lg:col-span-1 space-y-6">

                    <!-- SEO Scorecard -->
                    <div class="bg-white shadow-sm rounded-xl border border-slate-200 p-6 sticky top-6">
                        <h2 class="text-lg font-semibold text-slate-900 mb-1 flex items-center gap-2">
                            <span class="material-icons text-primary">analytics</span> Assistente SEO
                        </h2>
                        <p class="text-xs text-slate-400 mb-5">Verificação em tempo real das boas práticas.</p>

                        <!-- Score Circle -->
                        <div class="flex justify-center mb-6">
                            <div class="relative w-28 h-28">
                                <svg class="w-28 h-28 transform -rotate-90" viewBox="0 0 120 120">
                                    <circle cx="60" cy="60" r="50" fill="none" stroke="#e2e8f0" stroke-width="10" />
                                    <circle id="score-ring" cx="60" cy="60" r="50" fill="none" stroke="#cbd5e1"
                                        stroke-width="10" stroke-dasharray="314" stroke-dashoffset="314"
                                        stroke-linecap="round" style="transition: all 0.5s;" />
                                </svg>
                                <div class="absolute inset-0 flex flex-col items-center justify-center">
                                    <span class="text-3xl font-bold text-slate-900" id="seo-score">0</span>
                                    <span class="text-[10px] text-slate-400 uppercase tracking-wider">/ 100</span>
                                </div>
                            </div>
                        </div>

                        <!-- Checklist -->
                        <ul class="space-y-3" id="seo-checklist">
                            <li class="flex items-start gap-2 p-2 rounded-lg bg-slate-50" id="check-title">
                                <span class="material-icons text-lg seo-bad"
                                    id="icon-title">radio_button_unchecked</span>
                                <div>
                                    <p class="text-sm font-medium text-slate-700">Título otimizado</p>
                                    <p class="text-xs text-slate-400" id="hint-title">Ideal: 50–60 caracteres</p>
                                </div>
                            </li>
                            <li class="flex items-start gap-2 p-2 rounded-lg bg-slate-50" id="check-desc">
                                <span class="material-icons text-lg seo-bad"
                                    id="icon-desc">radio_button_unchecked</span>
                                <div>
                                    <p class="text-sm font-medium text-slate-700">Meta descrição</p>
                                    <p class="text-xs text-slate-400" id="hint-desc">Ideal: 150–160 caracteres</p>
                                </div>
                            </li>
                            <li class="flex items-start gap-2 p-2 rounded-lg bg-slate-50" id="check-content">
                                <span class="material-icons text-lg seo-bad"
                                    id="icon-content">radio_button_unchecked</span>
                                <div>
                                    <p class="text-sm font-medium text-slate-700">Conteúdo substancial</p>
                                    <p class="text-xs text-slate-400" id="hint-content">Mínimo: 300 palavras</p>
                                </div>
                            </li>
                            <li class="flex items-start gap-2 p-2 rounded-lg bg-slate-50" id="check-h2">
                                <span class="material-icons text-lg seo-bad" id="icon-h2">radio_button_unchecked</span>
                                <div>
                                    <p class="text-sm font-medium text-slate-700">Subtítulos (H2)</p>
                                    <p class="text-xs text-slate-400" id="hint-h2">Use ## para organizar seções</p>
                                </div>
                            </li>
                            <li class="flex items-start gap-2 p-2 rounded-lg bg-slate-50" id="check-image">
                                <span class="material-icons text-lg seo-bad"
                                    id="icon-image">radio_button_unchecked</span>
                                <div>
                                    <p class="text-sm font-medium text-slate-700">Imagem de capa</p>
                                    <p class="text-xs text-slate-400" id="hint-image">Defina uma imagem de destaque</p>
                                </div>
                            </li>
                            <li class="flex items-start gap-2 p-2 rounded-lg bg-slate-50" id="check-links">
                                <span class="material-icons text-lg seo-bad"
                                    id="icon-links">radio_button_unchecked</span>
                                <div>
                                    <p class="text-sm font-medium text-slate-700">Links internos/externos</p>
                                    <p class="text-xs text-slate-400" id="hint-links">Inclua pelo menos 1 link</p>
                                </div>
                            </li>
                        </ul>

                        <div class="mt-5 pt-4 border-t border-slate-100">
                            <p class="text-xs text-slate-400 leading-relaxed">
                                <span class="material-icons text-xs align-middle mr-1">lightbulb</span>
                                <strong>Dica:</strong> Use parágrafos curtos (3–4 linhas), listas e citações para
                                melhorar a legibilidade.
                            </p>
                        </div>
                    </div>

                    <!-- SERP Preview -->
                    <div class="bg-white shadow-sm rounded-xl border border-slate-200 p-6">
                        <h3 class="text-sm font-semibold text-slate-900 mb-3 flex items-center gap-2">
                            <span class="material-icons text-sm text-primary">search</span> Preview no Google
                        </h3>
                        <div class="border border-slate-200 rounded-lg p-4 bg-white">
                            <p class="text-[13px] text-green-700 truncate" id="serp-url">velt.com.br/blog/seu-artigo</p>
                            <p class="text-lg text-blue-700 font-medium leading-snug mt-0.5 line-clamp-2"
                                id="serp-title">Título do Artigo</p>
                            <p class="text-sm text-slate-500 mt-1 line-clamp-2" id="serp-desc">Descrição do artigo
                                aparecerá aqui...</p>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </main>

    <script>
        // Initialize EasyMDE
        const easyMDE = new EasyMDE({
            element: document.getElementById('markdown-editor'),
            spellChecker: false,
            autosave: { enabled: true, uniqueId: "velt_blog_post_<%= post ? post.filename : 'new' %>", delay: 1000 },
            minHeight: "400px",
            placeholder: "Comece a escrever seu artigo em Markdown...\n\n## Use subtítulos para organizar\n\nParágrafos curtos melhoram a legibilidade.",
            toolbar: [
                "bold", "italic", "heading-2", "heading-3", "|",
                "quote", "code", "unordered-list", "ordered-list", "|",
                "link", "image", "horizontal-rule", "|",
                "preview", "side-by-side", "fullscreen", "|",
                "guide"
            ],
            status: false
        });

        // DOM References
        const titleInput = document.getElementById('title');
        const descInput = document.getElementById('description');
        const imageInput = document.getElementById('image');
        const titleCounter = document.getElementById('title-counter');
        const descCounter = document.getElementById('desc-counter');
        const wordCountEl = document.getElementById('word-count');

        // Image Upload
        const uploadTrigger = document.getElementById('upload-trigger');
        const fileInput = document.getElementById('file-upload');
        uploadTrigger.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;
            const formData = new FormData();
            formData.append('image', file);
            uploadTrigger.innerHTML = '<span class="material-icons text-sm animate-spin">refresh</span> Enviando...';
            try {
                const response = await fetch('/admin/upload', { method: 'POST', body: formData });
                const data = await response.json();
                if (data.url) {
                    imageInput.value = data.url;
                    uploadTrigger.innerHTML = '<span class="material-icons text-sm text-green-600">check</span> Pronto!';
                    setTimeout(() => { uploadTrigger.innerHTML = '<span class="material-icons text-sm">cloud_upload</span> Upload'; }, 2000);
                    updateSEO();
                }
            } catch (err) {
                uploadTrigger.innerHTML = '<span class="material-icons text-sm text-red-500">error</span> Erro';
            }
        });

        // Image preview
        imageInput.addEventListener('input', () => {
            const url = imageInput.value;
            const previewContainer = document.getElementById('image-preview');
            const previewImg = document.getElementById('preview-img');
            if (url && (url.startsWith('http') || url.startsWith('/'))) {
                previewImg.src = url;
                previewContainer.classList.remove('hidden');
            } else {
                previewContainer.classList.add('hidden');
            }
        });

        // SEO Analysis
        function setCheck(id, passed) {
            const icon = document.getElementById(`icon-${id}`);
            icon.textContent = passed ? 'check_circle' : 'radio_button_unchecked';
            icon.className = `material-icons text-lg ${passed ? 'seo-good' : 'seo-bad'}`;
        }

        function updateSEO() {
            let score = 0;
            const maxScore = 6;

            // Title
            const titleLen = titleInput.value.length;
            titleCounter.textContent = `${titleLen} / 60 caracteres`;
            const titleOk = titleLen >= 30 && titleLen <= 65;
            titleCounter.className = `mt-1 text-xs seo-indicator ${titleOk ? 'seo-good' : (titleLen > 0 ? 'seo-warn' : 'seo-bad')}`;
            setCheck('title', titleOk);
            if (titleOk) score++;

            // Description
            const descLen = descInput.value.length;
            descCounter.textContent = `${descLen} / 160 caracteres`;
            const descOk = descLen >= 120 && descLen <= 165;
            descCounter.className = `mt-1 text-xs seo-indicator ${descOk ? 'seo-good' : (descLen > 0 ? 'seo-warn' : 'seo-bad')}`;
            setCheck('desc', descOk);
            if (descOk) score++;

            // Content word count
            const content = easyMDE.value();
            const words = content.trim().split(/\s+/).filter(w => w.length > 0);
            const wordCount = words.length;
            wordCountEl.textContent = `${wordCount} palavras`;
            const contentOk = wordCount >= 300;
            setCheck('content', contentOk);
            if (contentOk) score++;

            // Headings
            const hasH2 = /^#{2,3}\s/m.test(content);
            setCheck('h2', hasH2);
            if (hasH2) score++;

            // Image
            const imageOk = imageInput.value.length > 5;
            setCheck('image', imageOk);
            if (imageOk) score++;

            // Links
            const hasLinks = /\[.*?\]\(.*?\)/.test(content);
            setCheck('links', hasLinks);
            if (hasLinks) score++;

            // Update score
            const percentage = Math.round((score / maxScore) * 100);
            document.getElementById('seo-score').textContent = percentage;

            // Update ring
            const ring = document.getElementById('score-ring');
            const circumference = 314; // 2 * PI * 50
            const offset = circumference - (percentage / 100) * circumference;
            ring.style.strokeDashoffset = offset;
            if (percentage >= 80) ring.style.stroke = '#16a34a';
            else if (percentage >= 50) ring.style.stroke = '#eab308';
            else ring.style.stroke = '#cbd5e1';

            // Update SERP Preview
            const slug = titleInput.value.toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-');
            document.getElementById('serp-url').textContent = `velt.com.br/blog/${slug || 'seu-artigo'}`;
            document.getElementById('serp-title').textContent = titleInput.value || 'Título do Artigo';
            document.getElementById('serp-desc').textContent = descInput.value || 'Descrição do artigo aparecerá aqui...';
        }

        titleInput.addEventListener('input', updateSEO);
        descInput.addEventListener('input', updateSEO);
        imageInput.addEventListener('input', updateSEO);
        easyMDE.codemirror.on("change", updateSEO);

        // Trigger on load
        updateSEO();
        // Trigger image preview on load
        if (imageInput.value) imageInput.dispatchEvent(new Event('input'));
    </script>

</body>

</html>