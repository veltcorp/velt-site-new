<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Blog Velt</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { primary: '#FF6B00', secondary: '#1E293B' },
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-slate-50 text-slate-800 min-h-screen">

    <!-- Top Navigation -->
    <nav class="bg-secondary text-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center gap-8">
                    <span class="font-bold text-xl text-primary">Velt Admin</span>
                    <a href="/admin"
                        class="text-white/80 hover:text-white text-sm font-medium border-b-2 border-primary pb-[18px] pt-[20px]">
                        <span class="material-icons text-sm align-middle mr-1">article</span> Posts
                    </a>
                </div>
                <div class="flex items-center gap-4">
                    <a href="http://localhost:8082" target="_blank"
                        class="text-white/60 hover:text-white text-sm flex items-center gap-1">
                        Ver Site <span class="material-icons text-sm">open_in_new</span>
                    </a>
                    <a href="/admin/logout" class="text-white/60 hover:text-white text-sm flex items-center gap-1">
                        <span class="material-icons text-sm">logout</span> Sair
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">

        <!-- Header -->
        <div class="md:flex md:items-center md:justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-slate-900">Postagens do Blog</h1>
                <p class="mt-1 text-sm text-slate-500">Gerencie todos os artigos publicados no blog da Velt.</p>
            </div>
            <div class="mt-4 md:mt-0">
                <a href="/admin/new"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary text-white rounded-lg shadow-sm hover:bg-orange-700 transition font-medium text-sm">
                    <span class="material-icons text-sm">add</span> Nova Postagem
                </a>
            </div>
        </div>

        <!-- Posts Table -->
        <div class="bg-white shadow-sm rounded-xl border border-slate-200 overflow-hidden">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">
                            Título</th>
                        <th
                            class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider hidden sm:table-cell">
                            Autor</th>
                        <th
                            class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider hidden md:table-cell">
                            Data</th>
                        <th class="px-6 py-3 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">
                            Ações</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <% if (posts.length===0) { %>
                        <tr>
                            <td colspan="4" class="px-6 py-12 text-center">
                                <span class="material-icons text-5xl text-slate-300 mb-2 block">edit_note</span>
                                <p class="text-slate-500 font-medium">Nenhuma postagem encontrada.</p>
                                <p class="text-slate-400 text-sm">Clique em "Nova Postagem" para começar.</p>
                            </td>
                        </tr>
                        <% } %>
                            <% posts.forEach(post=> { %>
                                <tr class="hover:bg-slate-50/80 transition">
                                    <td class="px-6 py-4">
                                        <div class="text-sm font-semibold text-slate-900">
                                            <%= post.title %>
                                        </div>
                                        <div class="text-xs text-slate-400 mt-0.5">
                                            <%= post.filename %>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 hidden sm:table-cell">
                                        <span class="text-sm text-slate-600">
                                            <%= post.author %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 hidden md:table-cell">
                                        <span class="text-sm text-slate-500">
                                            <%= post.date %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <div class="flex justify-end items-center gap-2">
                                            <a href="/admin/edit/<%= post.filename %>"
                                                class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-indigo-700 bg-indigo-50 rounded-md hover:bg-indigo-100 transition">
                                                <span class="material-icons text-sm">edit</span> Editar
                                            </a>
                                            <a href="/blog/<%= post.filename.replace('.md', '.html') %>" target="_blank"
                                                class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-slate-600 bg-slate-100 rounded-md hover:bg-slate-200 transition">
                                                <span class="material-icons text-sm">visibility</span> Ver
                                            </a>
                                            <form action="/admin/delete" method="POST"
                                                onsubmit="return confirm('Tem certeza que deseja excluir este post?');"
                                                class="inline">
                                                <input type="hidden" name="filename" value="<%= post.filename %>">
                                                <button type="submit"
                                                    class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-red-700 bg-red-50 rounded-md hover:bg-red-100 transition cursor-pointer border-0">
                                                    <span class="material-icons text-sm">delete</span> Excluir
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                </tbody>
            </table>
        </div>

        <!-- Stats Footer -->
        <div class="mt-4 text-right text-xs text-slate-400">
            Total: <%= posts.length %> postagem(ns)
        </div>
    </main>

</body>

</html>